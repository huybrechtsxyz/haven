{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run: haven",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/strata/__main__.py",
      "args": "${input:cliArgs}",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug: haven",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/strata/__main__.py",
      "args": "${input:cliArgs}",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ],
  "inputs": [
    {
      "id": "cliArgs",
      "type": "promptString",
      "description": "CLI arguments (e.g. --help, version, deploy platform.yaml)",
      "default": "--help"
    }
  ]
}