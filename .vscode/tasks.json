{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xyz: validate",
      "type": "shell",
      "command": "xyz validate --file ${input:configFile}",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "xyz: deploy run",
      "type": "shell",
      "command": "xyz deploy run --file ${input:configFile}",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "xyz: build run",
      "type": "shell",
      "command": "xyz build run --file ${input:configFile}",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run: haven",
      "type": "shell",
      "command": "xyz ${input:cliArgs}",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "configFile",
      "type": "promptString",
      "description": "Config file path (e.g. @haven/deploy/deploy-prd.yaml)",
      "default": "@haven/deploy/deploy-prd.yaml"
    },
    {
      "id": "cliArgs",
      "type": "promptString",
      "description": "CLI arguments (e.g. version, validate --file @haven/deploy/deploy-prd.yaml)",
      "default": "version"
    }
  ]
}
