# =============================================================================
# Authentik Blueprint — Haven SSO Applications
# =============================================================================
# Generated by Ansible (hearth-config.yml) and applied automatically by the
# Authentik worker on startup from /blueprints/custom/.
#
# Client secrets are injected from Ansible vars (sourced from GitHub Secrets).
# Blueprints are idempotent — re-running updates existing resources in place.
# =============================================================================

version: 1
metadata:
  name: haven-apps
entries:

  # ---------------------------------------------------------------------------
  # MFA — bind validation stage to login flow (stages exist by default)
  # ---------------------------------------------------------------------------

  - model: authentik_flows.flowstagebinding
    state: present
    identifiers:
      target: !Find [authentik_flows.flow, [slug, default-authentication-flow]]
      stage: !Find [authentik_stages_authenticator_validate.authenticatorvalidatestage, [name, default-authentication-mfa-validation]]
    attrs:
      target: !Find [authentik_flows.flow, [slug, default-authentication-flow]]
      stage: !Find [authentik_stages_authenticator_validate.authenticatorvalidatestage, [name, default-authentication-mfa-validation]]
      order: 30

  # ---------------------------------------------------------------------------
  # Groups
  # ---------------------------------------------------------------------------

  - model: authentik_core.group
    state: present
    identifiers:
      name: admins
    attrs:
      name: admins
      attributes:
        description: Technical administrators — full access to all applications

  - model: authentik_core.group
    state: present
    identifiers:
      name: parents
    attrs:
      name: parents
      attributes:
        description: Parents — access to all family applications

  - model: authentik_core.group
    state: present
    identifiers:
      name: members
    attrs:
      name: members
      attributes:
        description: Family members — access to shared applications

  # ---------------------------------------------------------------------------
  # Group access policies
  # ---------------------------------------------------------------------------

  - model: authentik_policies_expression.expressionpolicy
    state: present
    identifiers:
      name: policy-group-admins
    id: policy-group-admins
    attrs:
      name: policy-group-admins
      description: Grants access to admins group members only
      expression: "return ak_is_group_member(request.user, name='admins')"

  - model: authentik_policies_expression.expressionpolicy
    state: present
    identifiers:
      name: policy-group-parents
    id: policy-group-parents
    attrs:
      name: policy-group-parents
      description: Grants access to parents and admins group members
      expression: "return ak_is_group_member(request.user, name='parents') or ak_is_group_member(request.user, name='admins')"

  - model: authentik_policies_expression.expressionpolicy
    state: present
    identifiers:
      name: policy-group-members
    id: policy-group-members
    attrs:
      name: policy-group-members
      description: Grants access to all family members (members, parents, and admins)
      expression: "return ak_is_group_member(request.user, name='members') or ak_is_group_member(request.user, name='parents') or ak_is_group_member(request.user, name='admins')"

  # ---------------------------------------------------------------------------
  # Vaultwarden — OAuth2/OIDC Provider + Application
  # ---------------------------------------------------------------------------

  - model: authentik_providers_oauth2.oauth2provider
    state: present
    identifiers:
      name: Vaultwarden
    id: provider-vaultwarden
    attrs:
      name: Vaultwarden
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      client_type: confidential
      client_id: vaultwarden
      client_secret: "{{ vaultwarden_sso_client_secret }}"
      redirect_uris:
        - matching_mode: strict
          url: "https://vault.huybrechts.xyz/identity/connect/oidc-signin"
      grant_types:
        - authorization_code
        - refresh_token
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, "authentik Self-signed Certificate"]]
      sub_mode: hashed_user_id
      issuer_mode: global

  - model: authentik_core.application
    state: present
    identifiers:
      slug: vaultwarden
    attrs:
      name: Vaultwarden
      slug: vaultwarden
      provider: !KeyOf provider-vaultwarden
      meta_launch_url: https://vault.huybrechts.xyz

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !Find [authentik_core.application, [slug, vaultwarden]]
      order: 0
    attrs:
      target: !Find [authentik_core.application, [slug, vaultwarden]]
      policy: !KeyOf policy-group-members
      order: 0
      enabled: true
      negate: false
      timeout: 30

  # ---------------------------------------------------------------------------
  # Infisical — OAuth2/OIDC Provider + Application
  # ---------------------------------------------------------------------------

  - model: authentik_providers_oauth2.oauth2provider
    state: present
    identifiers:
      name: Infisical
    id: provider-infisical
    attrs:
      name: Infisical
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      client_type: confidential
      client_id: infisical
      client_secret: "{{ infisical_sso_client_secret }}"
      redirect_uris:
        - matching_mode: strict
          url: "https://secrets.huybrechts.xyz/api/v1/sso/oidc/callback"
      grant_types:
        - authorization_code
        - refresh_token
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, "authentik Self-signed Certificate"]]
      sub_mode: hashed_user_id
      issuer_mode: global

  - model: authentik_core.application
    state: present
    identifiers:
      slug: infisical
    attrs:
      name: Infisical
      slug: infisical
      provider: !KeyOf provider-infisical
      meta_launch_url: https://secrets.huybrechts.xyz

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !Find [authentik_core.application, [slug, infisical]]
      order: 0
    attrs:
      target: !Find [authentik_core.application, [slug, infisical]]
      policy: !KeyOf policy-group-admins
      order: 0
      enabled: true
      negate: false
      timeout: 30

  # ---------------------------------------------------------------------------
  # WUD (What's Up Docker) — OAuth2/OIDC Provider + Application
  # ---------------------------------------------------------------------------

  - model: authentik_providers_oauth2.oauth2provider
    state: present
    identifiers:
      name: WUD
    id: provider-wud
    attrs:
      name: WUD
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      client_type: confidential
      client_id: wud
      client_secret: "{{ wud_sso_client_secret }}"
      redirect_uris:
        - matching_mode: strict
          url: "https://wud.huybrechts.xyz/auth/oidc/authentik/cb"
      grant_types:
        - authorization_code
        - refresh_token
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, "authentik Self-signed Certificate"]]
      sub_mode: hashed_user_id
      issuer_mode: global

  - model: authentik_core.application
    state: present
    identifiers:
      slug: wud
    attrs:
      name: WUD
      slug: wud
      provider: !KeyOf provider-wud
      meta_launch_url: https://wud.huybrechts.xyz

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !Find [authentik_core.application, [slug, wud]]
      order: 0
    attrs:
      target: !Find [authentik_core.application, [slug, wud]]
      policy: !KeyOf policy-group-admins
      order: 0
      enabled: true
      negate: false
      timeout: 30

  # ---------------------------------------------------------------------------
  # Portainer — OAuth2/OIDC Provider + Application
  # ---------------------------------------------------------------------------

  - model: authentik_providers_oauth2.oauth2provider
    state: present
    identifiers:
      name: Portainer
    id: provider-portainer
    attrs:
      name: Portainer
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      client_type: confidential
      client_id: portainer
      client_secret: "{{ portainer_sso_client_secret }}"
      redirect_uris:
        - matching_mode: strict
          url: "https://portainer.huybrechts.xyz/"
      grant_types:
        - authorization_code
        - refresh_token
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, "authentik Self-signed Certificate"]]
      sub_mode: hashed_user_id
      issuer_mode: global

  - model: authentik_core.application
    state: present
    identifiers:
      slug: portainer
    attrs:
      name: Portainer
      slug: portainer
      provider: !KeyOf provider-portainer
      meta_launch_url: https://portainer.huybrechts.xyz

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !Find [authentik_core.application, [slug, portainer]]
      order: 0
    attrs:
      target: !Find [authentik_core.application, [slug, portainer]]
      policy: !KeyOf policy-group-admins
      order: 0
      enabled: true
      negate: false
      timeout: 30

  # ---------------------------------------------------------------------------
  # Branding
  # ---------------------------------------------------------------------------

  - model: authentik_brands.brand
    state: present
    identifiers:
      domain: auth.huybrechts.xyz
    attrs:
      domain: auth.huybrechts.xyz
      branding_title: Haven
      default: true
