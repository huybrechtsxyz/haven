{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "automerge": false,
    "labels": [
        "dependencies"
    ],
    "customManagers": [
        {
            "customType": "regex",
            "fileMatch": [
                "config/.+/modules/mod-.+\\.yaml$"
            ],
            "matchStrings": [
                "image:\\s*(?<depName>[^:\\s]+):(?<currentValue>[^\\s]+)"
            ],
            "datasourceTemplate": "docker"
        }
    ]
}