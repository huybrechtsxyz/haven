# =============================================================================
# xyz-configuration — root .gitignore
# Pure-YAML infrastructure config repo
# =============================================================================

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# -----------------------------------------------------------------------------
# Editor artifacts  (personal, not team-shared)
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~
*.orig

# -----------------------------------------------------------------------------
# Secrets & environment files
# -----------------------------------------------------------------------------
.env
.env.*
*.secret.yaml
*.secrets.yaml
secrets/

# -----------------------------------------------------------------------------
# Logs (root-level; .platform/logs/ is covered by .platform/.gitignore)
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Python (scripts, tooling)
# -----------------------------------------------------------------------------
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# -----------------------------------------------------------------------------
# Terraform state & local overrides
# -----------------------------------------------------------------------------
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraformrc
terraform.rc

# -----------------------------------------------------------------------------
# Node (if tooling is ever added)
# -----------------------------------------------------------------------------
node_modules/
