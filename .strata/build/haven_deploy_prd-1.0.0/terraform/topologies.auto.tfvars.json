{
  "topologies": {
    "haven_swarm": {
      "type": "docker_swarm",
      "provider": "kamatera_eu_fr",
      "provisioner": "terraform",
      "components": [
        {
          "resource": "haven_vm_manager",
          "role": "manager",
          "count": 1
        },
        {
          "resource": "haven_vm_infra",
          "role": "worker",
          "count": 1
        },
        {
          "resource": "haven_vm_worker",
          "role": "worker",
          "count": 2
        }
      ],
      "volumes": [
        {
          "name": "config",
          "type": "replicated"
        },
        {
          "name": "docs",
          "type": "replicated"
        },
        {
          "name": "data",
          "type": "local"
        },
        {
          "name": "logs",
          "type": "local"
        },
        {
          "name": "serve",
          "type": "distributed"
        }
      ]
    }
  }
}