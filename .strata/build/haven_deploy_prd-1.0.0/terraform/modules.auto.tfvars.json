{
  "modules": {
    "haven_traefik": {
      "repository": "haven",
      "source_path": "services/traefik",
      "target_path": null,
      "description": "Traefik reverse proxy module for Haven \u2014 routing and TLS termination",
      "labels": {
        "version": "1.0.0"
      },
      "tags": [
        "haven",
        "traefik"
      ],
      "properties": {
        "mounts": [
          {
            "name": "configuration_files",
            "type": "config",
            "change_mod": "0644",
            "target_path": "${TRAEFIK_PATH_CONFIG}",
            "source_path": "config",
            "description": "Traefik static configuration"
          },
          {
            "name": "certificates",
            "type": "config",
            "change_mod": "0600",
            "target_path": "${TRAEFIK_PATH_CERTS}",
            "description": "TLS certificates"
          },
          {
            "name": "documentation",
            "type": "docs",
            "change_mod": "0644",
            "target_path": "${TRAEFIK_PATH_DOCS}",
            "source_path": "docs/traefik",
            "description": "Module documentation"
          },
          {
            "name": "datafiles",
            "type": "data",
            "change_mod": "0600",
            "target_path": "${TRAEFIK_PATH_DATA}",
            "description": "Certificate storage (ACME)"
          },
          {
            "name": "logging",
            "type": "logs",
            "change_mod": "0644",
            "target_path": "${TRAEFIK_PATH_LOGS}",
            "description": "Access and error logs"
          }
        ],
        "checks": [
          {
            "name": "traefik_http_check",
            "label": "Traefik HTTP Health Check",
            "target": "consul",
            "type": "http",
            "interval": "60s",
            "timeout": "5s",
            "retries": 3
          }
        ],
        "endpoints": [
          {
            "name": "traefik_dashboard",
            "label": "Traefik Dashboard",
            "url": "http://localhost:8080/dashboard/"
          }
        ]
      }
    }
  }
}