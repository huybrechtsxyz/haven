{
  "resources": {
    "haven_vm_manager": {
      "type": "virtualmachine",
      "provider": "kamatera",
      "category": "compute",
      "subcategory": "virtualmachine",
      "unit_cost": 5.0,
      "description": "Kamatera Virtual Machine for Haven Docker Swarm manager node",
      "labels": {
        "version": "1.0.0"
      },
      "tags": [
        "haven",
        "vm",
        "manager"
      ],
      "configuration": {
        "os_name": "Ubuntu",
        "os_code": "24.04 64bit",
        "cpu_type": "A",
        "cpu_cores": 1,
        "ram_mb": 1024,
        "billing": "hourly"
      },
      "storage": {
        "install_path": "/opt/install/haven",
        "disks": [
          {
            "size": 20,
            "label": "haven-vm-manager-os",
            "mount": "/mnt/data1"
          }
        ],
        "volumes": [
          {
            "name": "config",
            "path": "/mnt/data1/etc/haven"
          },
          {
            "name": "docs",
            "path": "/mnt/data1/var/docs/haven"
          },
          {
            "name": "data",
            "path": "/mnt/data1/var/data/haven"
          },
          {
            "name": "logs",
            "path": "/mnt/data1/var/logs/haven"
          },
          {
            "name": "serve",
            "path": "/mnt/data1/var/serve"
          }
        ]
      },
      "firewall": "haven_vm_manager_merged_fw"
    },
    "haven_vm_infra": {
      "type": "virtualmachine",
      "provider": "kamatera",
      "category": "compute",
      "subcategory": "virtualmachine",
      "unit_cost": 11.0,
      "description": "Kamatera Infrastructure VM \u2014 databases and infrastructure services (Postgres, Redis, GlusterFS)",
      "labels": {
        "version": "1.0.0"
      },
      "tags": [
        "haven",
        "vm",
        "infra"
      ],
      "configuration": {
        "os_name": "Ubuntu",
        "os_code": "24.04 64bit",
        "cpu_type": "A",
        "cpu_cores": 1,
        "ram_mb": 4096,
        "billing": "hourly",
        "disk_size": 40
      },
      "storage": {
        "install_path": "/opt/install/haven",
        "disks": [
          {
            "size": 20,
            "label": "haven-vm-infra-os",
            "mount": "/mnt/data1"
          },
          {
            "size": 40,
            "label": "haven-vm-infra-data",
            "mount": "/mnt/data2"
          }
        ],
        "volumes": [
          {
            "name": "config",
            "path": "/mnt/data2/etc/haven"
          },
          {
            "name": "docs",
            "path": "/mnt/data2/var/docs/haven"
          },
          {
            "name": "data",
            "path": "/mnt/data2/var/data/haven"
          },
          {
            "name": "logs",
            "path": "/mnt/data2/var/logs/haven"
          },
          {
            "name": "serve",
            "path": "/mnt/data2/var/serve"
          }
        ]
      },
      "firewall": "haven_vm_infra_merged_fw"
    },
    "haven_vm_worker": {
      "type": "virtualmachine",
      "provider": "kamatera",
      "category": "compute",
      "subcategory": "virtualmachine",
      "unit_cost": 6.0,
      "description": "Kamatera Virtual Machine for Haven Docker Swarm worker node \u2014 runs application containers",
      "labels": {
        "version": "1.0.0"
      },
      "tags": [
        "haven",
        "vm",
        "worker"
      ],
      "configuration": {
        "os_name": "Ubuntu",
        "os_code": "24.04 64bit",
        "cpu_type": "A",
        "cpu_cores": 1,
        "ram_mb": 2048,
        "billing": "hourly"
      },
      "storage": {
        "install_path": "/opt/install/haven",
        "disks": [
          {
            "size": 20,
            "label": "haven-vm-worker-os",
            "mount": "/mnt/data1"
          }
        ],
        "volumes": [
          {
            "name": "config",
            "path": "/mnt/data1/etc/haven"
          },
          {
            "name": "docs",
            "path": "/mnt/data1/var/docs/haven"
          },
          {
            "name": "data",
            "path": "/mnt/data1/var/data/haven"
          },
          {
            "name": "logs",
            "path": "/mnt/data1/var/logs/haven"
          },
          {
            "name": "serve",
            "path": "/mnt/data1/var/serve"
          }
        ]
      },
      "firewall": "haven_vm_worker_merged_fw"
    }
  }
}